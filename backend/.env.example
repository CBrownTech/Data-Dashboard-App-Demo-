# .env.example — commit this file, NOT .env
# Copy this to .env and fill in your real values before running the app.

# Which database backend to use:
#   sqlite   — local file, zero cloud setup. Default. Best for demos/dev.
#   bigquery — Google BigQuery (requires the two BigQuery settings below).
DB_BACKEND=sqlite

# --- Local demo (DB_BACKEND=sqlite) ---
# Optional path to the SQLite file. Defaults to backend/local_demo.db (gitignored).
# SQLITE_DB_PATH=local_demo.db

# --- BigQuery (DB_BACKEND=bigquery) ---
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# BIGQUERY_PROJECT=your-gcp-project-id
# BIGQUERY_DATASET=bank_db

JWT_SECRET=your-secret-key-change-in-production
